{
  "_meta": {
    "category": "quality",
    "version": "0.2",
    "notes": "Quality/detail modifiers. Upgraded with aliases/related/requires/excludes. Conservative tags to avoid overcooking most models."
  },

  "high detail": {
    "tags": ["highly detailed", "sharp focus"],
    "aliases": ["highly detailed", "detailed", "detail", "more detail", "high details"],
    "related": ["ultra", "clean", "sharp"],
    "excludes": ["soft", "low detail"]
  },

  "film grain": {
    "tags": ["film grain"],
    "aliases": ["grain", "analog grain", "movie grain"],
    "related": ["noir", "vintage", "cinematic"],
    "excludes": ["smooth", "clean"]
  },

  "clean": {
    "tags": ["clean lines", "crisp"],
    "aliases": ["crisp", "clean", "smooth lines", "polished"],
    "related": ["sharp", "studio", "high detail"],
    "excludes": ["film grain", "noise", "gritty"]
  },

  "soft": {
    "tags": ["soft focus"],
    "aliases": ["soft", "dreamy", "gentle focus"],
    "related": ["low contrast", "bloom", "pastel"],
    "excludes": ["sharp", "high detail", "ultra"]
  },

  "ultra": {
    "tags": ["ultra detailed"],
    "aliases": ["ultra", "ultra detail", "extreme detail", "ultra-detailed"],
    "related": ["high detail", "sharp"],
    "excludes": ["soft", "low detail"]
  },

  "sharp": {
    "tags": ["sharp focus", "high clarity"],
    "aliases": ["sharp", "crisp focus", "high clarity"],
    "related": ["clean", "high detail"],
    "excludes": ["soft", "motion blur"]
  },

  "low detail": {
    "tags": ["simple details", "low detail"],
    "aliases": ["low detail", "minimal detail", "simplified"],
    "related": ["minimal", "flat"],
    "excludes": ["high detail", "ultra", "sharp"]
  },

  "noise": {
    "tags": ["subtle noise", "texture noise"],
    "aliases": ["noise", "textured noise", "sensor noise"],
    "related": ["film grain", "vintage"],
    "excludes": ["clean", "smooth"]
  },

  "vintage": {
    "tags": ["vintage look", "aged texture", "slight fading"],
    "aliases": ["vintage", "aged", "old photo", "retro"],
    "related": ["film grain", "noir", "muted"],
    "excludes": ["clean", "modern"]
  },

  "noir": {
    "tags": ["noir look", "high contrast", "deep shadows"],
    "aliases": ["noir", "film noir", "dark noir"],
    "related": ["film grain", "vintage", "dramatic"],
    "excludes": ["pastel", "bright", "low contrast"]
  },

  "bloom": {
    "tags": ["soft bloom", "glow highlights"],
    "aliases": ["bloom", "soft glow", "highlight glow"],
    "related": ["soft", "dreamy", "cinematic"],
    "excludes": ["clean", "sharp"]
  },

  "matte": {
    "tags": ["matte finish", "soft highlights"],
    "aliases": ["matte", "matte finish"],
    "related": ["soft", "film grain"],
    "excludes": ["glossy"]
  },

  "glossy": {
    "tags": ["glossy finish", "specular highlights"],
    "aliases": ["glossy", "shiny", "high shine"],
    "related": ["sharp", "clean"],
    "excludes": ["matte"]
  }
}